# Apple 官翻 Mac 监控工具 —— 部署配置示例
# 复制本文件为 .env 后填入实际值

# ===== Web 管理面板（部署时唯一必填） =====
# 管理员密钥，网页端保存配置时必须输入
ADMIN_SECRET=your-strong-secret

# HTTP 服务端口
PORT=3000

# 前端独立部署来源（可选）
# 例如前端部署在 GitHub Pages 时：FRONTEND_ORIGIN=https://username.github.io
# 不配置则只允许同域访问
FRONTEND_ORIGIN=

# ===== 监控设置 =====
# 监控的机型，多个用逗号分隔
WATCH_MODELS=macmini,macstudio,macpro

# Apple 官翻页面 URL（新加坡 ECS 如访问中国页面异常，可换成对应国家/地区页面）
APPLE_REFURB_URL=https://www.apple.com.cn/shop/refurbished/mac

# HTTP 请求超时（毫秒）
FETCH_TIMEOUT=15000

# 检查间隔（毫秒），默认 5 分钟
CHECK_INTERVAL_MS=300000

# 同一机型上架后连续提醒次数，默认 1（仅提醒一次）
REMINDER_REPEAT_COUNT=1

# ===== 通知通道（当前仅支持飞书） =====
NOTIFY_CHANNEL=feishu

# 飞书自定义机器人 webhook 完整地址
# 获取方式：飞书群设置 → 添加群机器人 → 自定义机器人 → 复制 webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxx

# 飞书自定义机器人密钥（如果启用了“签名验证”则必填，否则留空）
FEISHU_SECRET=

# ===== 状态持久化 =====
# ECS/本地部署推荐使用 local
STATE_BACKEND=local

# 本地状态文件路径（保持默认即可）
LOCAL_STATE_PATH=./state.json

# 腾讯云 COS 配置（仅 STATE_BACKEND=cos 时生效）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_STATE_KEY=apple-refurb-monitor/state.json

# ===== HTTPS（Nginx + Let's Encrypt + Cloudflare，必填） =====
# 你解析到 ECS 的域名
DOMAIN=your-domain.com

# Let's Encrypt 证书通知邮箱
LETSENCRYPT_EMAIL=your-email@example.com
